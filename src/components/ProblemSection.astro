---
const problems = [
  {
    name: "Missed Calls = Lost Customers",
    body: "62% of calls to service businesses go unanswered. Every missed call is a customer walking away.",
    // Lucide phone-off
    iconPath: "M10.68 13.31a16 16 0 0 0 3.41 2.6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7 2 2 0 0 1 1.72 2v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91M22 2 2 22",
  },
  {
    name: "Slow Follow-Up Kills Deals",
    body: "Leads not contacted within 5 minutes are 10× less likely to convert. Most teams take hours.",
    // Lucide clock
    iconPath: "M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zM12 6v6l4 2",
  },
  {
    name: "20+ Hours of Wasted Effort",
    body: "Your team spends 20+ hours/week on repetitive tasks AI handles in seconds.",
    // Lucide loader / repeat
    iconPath: "M21 12a9 9 0 1 1-6.5-8.7M21 4v5h-5",
  },
];
---
<section class="border-b border-border">
  <div class="max-w-6xl mx-auto px-6 py-24">
    <h2 class="text-center mb-4">Sound Familiar?</h2>
    <p class="text-center text-text-secondary max-w-xl mx-auto mb-16">
      The same three problems show up at every service business we audit.
    </p>
    <div class="grid md:grid-cols-3 gap-6">
      {problems.map((p) => (
        <div class="bg-bg-elevated border border-border rounded-xl p-8 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-accent/10 transition-all">
          <svg
            class="w-10 h-10 text-accent mb-6"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d={p.iconPath} />
          </svg>
          <h3 class="mb-3">{p.name}</h3>
          <p class="text-text-secondary text-base leading-relaxed">{p.body}</p>
        </div>
      ))}
    </div>
    <div class="text-center mt-12">
      <a href="#process" class="text-accent hover:text-accent-hover transition-colors inline-flex items-center gap-1">
        There's a better way
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="translate-y-px">
          <path d="M12 5v14M19 12l-7 7-7-7" />
        </svg>
      </a>
    </div>
  </div>
</section>
