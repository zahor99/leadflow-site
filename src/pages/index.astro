---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import CredibilityBar from "../components/CredibilityBar.astro";
import ProblemSection from "../components/ProblemSection.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import ServiceCards from "../components/ServiceCards.astro";
import ROICalculator from "../components/ROICalculator.astro";
import CaseStudy from "../components/CaseStudy.astro";
import PricingTable from "../components/PricingTable.astro";
import FAQ from "../components/FAQ.astro";
import CTAFooter from "../components/CTAFooter.astro";
