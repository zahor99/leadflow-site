---
import Base from "../layouts/Base.astro";
---
<Base
  title="AI Systems That Work While You Sleep"
  description="We build AI automation systems for service businesses — from lead capture to follow-up to booking. You keep running your business."
>
  <main class="min-h-screen flex flex-col">
    <!-- Sticky nav -->
    <header class="sticky top-0 z-30 backdrop-blur-md bg-bg-deep/70 border-b border-border">
      <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-bold text-xl tracking-tight">
          Lead<span class="text-accent">Flow</span>
        </a>
        <div class="flex items-center gap-6 text-sm text-text-secondary">
          <span class="hidden sm:inline opacity-60">Site launching soon</span>
        </div>
      </nav>
    </header>

    <!-- Hero -->
    <section class="flex-1 flex items-center bg-hero-glow">
      <div class="max-w-4xl mx-auto px-6 py-24 text-center">
        <p class="text-accent font-medium tracking-wider uppercase text-xs mb-6">
          AI Automation for Service Businesses
        </p>
        <h1 class="mb-6">
          AI Systems That Work<br />While You Sleep.
        </h1>
        <p class="text-lg sm:text-xl text-text-secondary leading-relaxed max-w-2xl mx-auto mb-10">
          We build AI automation for lead capture, follow-up, and booking.
          You keep running your business.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center items-center">
          <a
            href="mailto:hello@leadflowautomation.com?subject=AI Audit Request"
            class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent text-white font-medium hover:bg-accent-hover transition-all hover:scale-[1.02] shadow-lg shadow-accent/20"
          >
            Book My Free AI Audit →
          </a>
          <span class="text-text-secondary text-sm">15 minutes · No obligation · No sales pitch</span>
        </div>

        <p class="mt-16 text-text-secondary text-sm opacity-60">
          Full site launching shortly. Reply to that email for early access.
        </p>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-border">
      <div class="max-w-6xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-sm text-text-secondary">
        <span>
          <strong class="text-text-primary">Lead Flow Automation</strong> ·
          <a href="mailto:hello@leadflowautomation.com" class="hover:text-accent">hello@leadflowautomation.com</a>
        </span>
        <span class="opacity-70">© 2026 Lead Flow Automation</span>
      </div>
    </footer>
  </main>
</Base>
